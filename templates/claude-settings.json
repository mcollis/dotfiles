{
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "model": "opus",
  "permissions": {
    "allow": [
      "Skill(commit-message)",
      "Bash(glab mr list*)",
      "Bash(glab mr view*)",
      "Bash(glab mr note list*)",
      "Bash(glab mr checks*)",
      "Bash(glab mr diff*)",
      "Bash(glab issue list*)",
      "Bash(glab issue view*)",
      "Bash(jira-cli issue view*)",
      "Bash(jira-cli issue list*)",
      "Bash(jira-cli sprint list*)",
      "Read(/tmp/**)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git -C * commit*)",
      "Bash(git push*)",
      "Bash(git -C * push*)",
      "Bash(git rebase*)",
      "Bash(git -C * rebase*)",
      "Bash(git reset --hard*)",
      "Bash(git -C * reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git -C * branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git -C * branch -d*)",
      "Bash(git tag -d*)",
      "Bash(git tag --delete*)",
      "Bash(git -C * tag -d*)",
      "Bash(git -C * tag --delete*)",
      "Bash(git worktree*)",
      "Bash(git -C * worktree*)",
      "Bash(git clean *)",
      "Bash(git -C * clean *)",
      "Bash(git restore *)",
      "Bash(git -C * restore *)",
      "Bash(git checkout -- *)",
      "Bash(git -C * checkout -- *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(unlink *)",
      "Bash(shred *)",
      "Bash(find * -delete *)",
      "Bash(find * -exec *)",
      "Bash(sh -c *)",
      "Bash(bash -c *)",
      "Bash(zsh -c *)",
      "Bash(sudo *)",
      "Bash(doas *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn npm publish *)",
      "Bash(cargo publish *)",
      "Bash(twine upload *)",
      "Bash(glab mr create*)",
      "Bash(glab mr merge*)",
      "Bash(glab mr close*)",
      "Bash(glab mr note create*)",
      "Bash(glab mr update*)",
      "Bash(glab issue create*)",
      "Bash(glab issue close*)",
      "Bash(glab issue update*)",
      "Bash(glab release create*)",
      "Bash(glab release delete*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh pr review*)",
      "Bash(gh issue create*)",
      "Bash(gh issue close*)",
      "Bash(gh issue edit*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)"
    ]
  },
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "padding": 0,
    "type": "command"
  },
  "teammateMode": "auto",
  "theme": "dark-ansi",
  "tui": "fullscreen"
}
