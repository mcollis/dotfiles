# Shared, durable approval policy.
prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Require confirmation before committing.",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Require confirmation before pushing.",
)

# Destructive filesystem, repository, and system operations.
prefix_rule(pattern = ["rm"], decision = "prompt")
prefix_rule(pattern = ["rmdir"], decision = "prompt")
prefix_rule(pattern = ["unlink"], decision = "prompt")
prefix_rule(pattern = ["shred"], decision = "prompt")
prefix_rule(pattern = ["git", "clean"], decision = "prompt")
prefix_rule(pattern = ["git", "restore"], decision = "prompt")
prefix_rule(pattern = ["git", "checkout", "--"], decision = "prompt")
prefix_rule(pattern = ["git", "rebase"], decision = "prompt")
prefix_rule(pattern = ["git", "reset", "--hard"], decision = "prompt")
prefix_rule(pattern = ["git", "branch", "-d"], decision = "prompt")
prefix_rule(pattern = ["git", "branch", "-D"], decision = "prompt")
prefix_rule(pattern = ["git", "tag", "-d"], decision = "prompt")
prefix_rule(pattern = ["git", "tag", "--delete"], decision = "prompt")
prefix_rule(pattern = ["git", "worktree"], decision = "prompt")
prefix_rule(pattern = ["sudo"], decision = "prompt")
prefix_rule(pattern = ["doas"], decision = "prompt")
prefix_rule(pattern = ["dd"], decision = "prompt")
prefix_rule(pattern = ["mkfs"], decision = "prompt")

# Shell wrappers and package publication can execute arbitrary or external work.
prefix_rule(pattern = ["sh", "-c"], decision = "prompt")
prefix_rule(pattern = ["bash", "-c"], decision = "prompt")
prefix_rule(pattern = ["zsh", "-c"], decision = "prompt")
prefix_rule(pattern = ["npm", "publish"], decision = "prompt")
prefix_rule(pattern = ["pnpm", "publish"], decision = "prompt")
prefix_rule(pattern = ["yarn", "npm", "publish"], decision = "prompt")
prefix_rule(pattern = ["cargo", "publish"], decision = "prompt")
prefix_rule(pattern = ["twine", "upload"], decision = "prompt")

# Externally visible GitHub and GitLab writes.
prefix_rule(pattern = ["glab", "mr", "create"], decision = "prompt")
prefix_rule(pattern = ["glab", "mr", "merge"], decision = "prompt")
prefix_rule(pattern = ["glab", "mr", "close"], decision = "prompt")
prefix_rule(pattern = ["glab", "mr", "note", "create"], decision = "prompt")
prefix_rule(pattern = ["glab", "mr", "update"], decision = "prompt")
prefix_rule(pattern = ["glab", "issue", "create"], decision = "prompt")
prefix_rule(pattern = ["glab", "issue", "close"], decision = "prompt")
prefix_rule(pattern = ["glab", "issue", "update"], decision = "prompt")
prefix_rule(pattern = ["glab", "release", "create"], decision = "prompt")
prefix_rule(pattern = ["glab", "release", "delete"], decision = "prompt")
prefix_rule(pattern = ["gh", "pr", "create"], decision = "prompt")
prefix_rule(pattern = ["gh", "pr", "merge"], decision = "prompt")
prefix_rule(pattern = ["gh", "pr", "close"], decision = "prompt")
prefix_rule(pattern = ["gh", "pr", "review"], decision = "prompt")
prefix_rule(pattern = ["gh", "issue", "create"], decision = "prompt")
prefix_rule(pattern = ["gh", "issue", "close"], decision = "prompt")
prefix_rule(pattern = ["gh", "issue", "edit"], decision = "prompt")
prefix_rule(pattern = ["gh", "release", "create"], decision = "prompt")
prefix_rule(pattern = ["gh", "release", "delete"], decision = "prompt")

# Read-only issue and merge-request lookups.
prefix_rule(pattern = ["jira-cli", "issue", "list"], decision = "allow")
prefix_rule(pattern = ["jira-cli", "issue", "view"], decision = "allow")
prefix_rule(pattern = ["glab", "mr", "view"], decision = "allow")

# Read-only Git and Worktrunk inspection.
prefix_rule(pattern = ["git", "status"], decision = "allow")
prefix_rule(pattern = ["git", "diff"], decision = "allow")
prefix_rule(pattern = ["git", "log"], decision = "allow")
prefix_rule(pattern = ["git", "show"], decision = "allow")
prefix_rule(pattern = ["git", "worktree", "list"], decision = "allow")
prefix_rule(pattern = ["wt", "list"], decision = "allow")

# Read-only Docker inspection.
prefix_rule(pattern = ["docker", "ps"], decision = "allow")
prefix_rule(pattern = ["docker", "inspect"], decision = "allow")
prefix_rule(pattern = ["docker", "compose", "ps"], decision = "allow")
